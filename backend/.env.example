# Database
DATABASE_URL=postgresql+asyncpg://twentymts:twentymts@localhost:5432/twentymts

# Instruments
# leader_symbol: the "Dow" proxy instrument (e.g. MYM.c.0 for CME Micro
# E-mini Dow futures, continuous front month)
LEADER_SYMBOL=DIA
STOCK_SYMBOL=AAPL

# Data feed provider: "simulated" (dev/testing), "schwab" (live market data),
# or "replay" (historical CSV backtesting)
DATA_FEED_PROVIDER=simulated

# Schwab API (obtain at developer.schwab.com)
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=
SCHWAB_REDIRECT_URI=https://127.0.0.1
SCHWAB_TOKENS_PATH=schwab_tokens.json
SCHWAB_POLL_INTERVAL_SECONDS=1.0

# Replay feed (DATA_FEED_PROVIDER=replay)
# REPLAY_SPEED: 0 = as fast as possible, 1.0 = real-time, 2.0 = 2x speed, etc.
REPLAY_FILE_PATH=data/sample_replay.csv
REPLAY_SPEED=0

# Databento (historical data for replay/backtesting) - obtain at databento.com
DATABENTO_API_KEY=

# Signal Engine Thresholds (all configurable)
SYNC_WINDOW_SECONDS=300
SYNC_CORRELATION_THRESHOLD=0.70
JOINT_DECLINE_WINDOW_SECONDS=12
JOINT_DECLINE_MIN_RETURN=-0.0005
EMA_PERIOD_SECONDS=25
DIVERGENCE_DIA_CONSECUTIVE_TICKS=3
DIVERGENCE_RETURN_WINDOW_SECONDS=5
DIVERGENCE_EXPIRY_SECONDS=120
RECONNECTION_CONSECUTIVE_TICKS=2
RECONNECTION_LOOKBACK_SECONDS=10

# Market Hours (ET)
HIGH_VOLATILITY_WINDOW_MINUTES=30

# Feature Flags
NEWS_FILTER_ACTIVE=false

# Dev/testing: set to false to let SimulatedFeed run outside 9:30-16:00 ET.
# Keep true once trading against the real Schwab feed.
RESPECT_MARKET_HOURS=true
